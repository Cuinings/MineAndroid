<?xml version="1.0" encoding="utf-8"?>
<layout>
    <com.cn.core.ui.view.frosted.FocusScaleView xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="@dimen/dp60"
        android:layout_height="@dimen/dp56"
        android:focusable="true"
        android:focusableInTouchMode="false"

        app:sgv_cornerRadius="@dimen/dp8"

        app:sgv_overlayEnabled="false"
        app:sgv_overlayColorNormal="@color/common_color_solid_normal"
        app:sgv_overlayColorPressed="@color/common_color_solid_normal"
        app:sgv_overlayColorFocused="@color/common_color_solid_normal"

        app:sgv_strokeEnabled="true"
        app:sgv_strokeWidthNormal="@dimen/dp0point5"
        app:sgv_strokeWidthFocused="@dimen/dp1"
        app:sgv_strokeWidthPressed="@dimen/dp0"
        app:sgv_strokeWidthDisabled="@dimen/dp0"
        app:sgv_strokeWidthSelected="@dimen/dp0"
        app:sgv_strokeColorNormal="@color/common_color_stroke_normal_step_a"
        app:sgv_strokeColorFocused="@color/common_color_stroke_focused"

        app:sgv_glowEnabled="true"
        app:sgv_glowDrawableNormal="@drawable/icon_frost_osd_main"
        app:sgv_topHighlightColor="@color/common_color_top_light_normal_step_a"

        app:asgv_refreshEffectEnabled="true"
        app:asgv_flowEnabled="false"
        app:asgv_flowColor="@color/white"

        app:fagv_blurEnabled="false"

        app:fsv_focusScale="1.11"
        app:fsv_scaleDuration="300"

        app:selected="@{info.select || info.deleting}"

        android:id="@+id/itemSoftLayout">

        <ImageView
            android:id="@+id/ivtpIcon"
            android:layout_width="@dimen/dp24"
            android:layout_height="@dimen/dp24"
            android:layout_marginTop="@dimen/dp10"
            android:layout_centerHorizontal="true"
            android:scaleType="centerInside"
            android:duplicateParentState="true"
            android:focusable="false"
            app:packageName="@{info.appInfo.packageName}"
            app:clazz="@{info.appInfo.clazz}"
            app:appType="@{info.appInfo.appType}"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

        <ImageView
            android:id="@+id/ivThirdIcon"
            android:layout_width="@dimen/dp16"
            android:layout_height="@dimen/dp16"
            android:layout_centerHorizontal="true"
            android:scaleType="fitXY"
            android:focusable="false"
            app:imgBitmap="@{info.bitmap}"
            app:layout_constraintStart_toStartOf="@id/ivtpIcon"
            app:layout_constraintEnd_toEndOf="@id/ivtpIcon"
            app:layout_constraintTop_toTopOf="@id/ivtpIcon"
            app:layout_constraintBottom_toBottomOf="@id/ivtpIcon"/>

        <TextView
            android:id="@+id/tvSoftName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dp3"
            android:layout_marginEnd="@dimen/dp3"
            android:layout_marginTop="@dimen/dp38"
            android:includeFontPadding="false"
            android:textSize="@dimen/sp7"
            android:textColor="@color/white"
            android:gravity="center_horizontal"
            android:maxLines="2"
            android:ellipsize="end"
            android:focusable="false"
            app:info="@{info.appInfo}"
            app:type="@{false}"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

        <ImageView
            android:id="@+id/ivSelect"
            android:layout_width="@dimen/dp12"
            android:layout_height="@dimen/dp12"
            android:layout_marginTop="@dimen/dp2"
            android:layout_marginEnd="@dimen/dp2"
            android:scaleType="centerInside"
            android:visibility="gone"
            android:focusable="false"
            app:main="@{info}"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

    </com.cn.core.ui.view.frosted.FocusScaleView>
    <data>
        <variable
            name="info"
            type="com.cn.board.home.entity.SoftEntity" />
    </data>

</layout>