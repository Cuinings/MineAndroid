<?xml version="1.0" encoding="utf-8"?>
<resources>
    <declare-styleable name="FrostedGlassView">
        <!-- 圆角半径属性 -->
        <attr name="cornerRadius" format="dimension" />
        <!-- 单个角的圆角半径属性 -->
        <attr name="topLeftRadius" format="dimension" />
        <attr name="topRightRadius" format="dimension" />
        <attr name="bottomLeftRadius" format="dimension" />
        <attr name="bottomRightRadius" format="dimension" />
    </declare-styleable>

    <declare-styleable name="FrostedGlowView">
        <!-- 圆角半径属性 -->
        <attr name="cornerRadius" />
        <!-- 单个角的圆角半径属性 -->
        <attr name="topLeftRadius" />
        <attr name="topRightRadius" />
        <attr name="bottomLeftRadius" />
        <attr name="bottomRightRadius" />
        <!-- 内发光属性 -->
        <attr name="glowColor" format="color"/>
        <attr name="glowRadius" format="dimension"/>
        <attr name="glowStrokeWidth" format="dimension"/>
        <attr name="glowStrokeColor" format="color"/>
        <attr name="innerShadowThickness" format="dimension"/>
        <attr name="innerShadowColor" format="color"/>
    </declare-styleable>
    <declare-styleable name="MicrophoneView">
        <attr name="scaleValue" format="float"/>

        <attr name="waringColor" format="color"/>
        <attr name="waringFocusColor" format="color"/>

        <attr name="micOnColor" format="color"/>
        <attr name="micOnFocusColor" format="color"/>

        <attr name="micOffColor" format="color"/>
        <attr name="micOffFocusColor" format="color"/>

        <attr name="energyNormalColor" format="color"/>
        <attr name="energyNormalFocusColor" format="color"/>

        <attr name="energyColor" format="color"/>

        <attr name="roundBackgroundColor" format="color"/>
        <attr name="roundBackgroundFocusColor" format="color"/>

        <attr name="waringPath" format="string"/>
        <attr name="offPath" format="string"/>
        <attr name="onPath" format="string"/>
        <attr name="energyPath" format="string"/>

        <attr name="energy" format="float"/>
        <attr name="energyLeft" format="float"/>
        <attr name="energyTop" format="float"/>
        <attr name="energyRight" format="float"/>
        <attr name="energyBottom" format="float"/>
    </declare-styleable>

    <declare-styleable name="PagedTextView">
        <!-- 文本大小 -->
        <attr name="textSize" format="dimension" />
        <!-- 文本颜色 -->
        <attr name="textColor" format="color" />
        <!-- 支持标准的android:text属性 -->
        <attr name="android:text" />
    </declare-styleable>


    <declare-styleable name="LoadingView">
        <attr name="gradientRingStartColor" format="color"/>
        <attr name="gradientRingEndColor" format="color"/>
    </declare-styleable>

    <declare-styleable name="InnerGlowView">
        <attr name="innerGlowColor" format="color"/>
        <attr name="innerGlowRadius" format="dimension"/>
        <attr name="innerGlowCornerRadius" format="dimension"/>
        <attr name="innerGlowStrokeWidth" format="dimension"/>
        <attr name="innerGlowStrokeColor" format="color"/>
        <attr name="innerGlowShadowThickness" format="dimension"/>
        <attr name="innerGlowShadowColor" format="color"/>
        <attr name="innerGlowBlurEnabled" format="boolean"/>
        <attr name="innerGlowBlurRadius" format="dimension"/>
        <attr name="innerGlowLiveBlurEnabled" format="boolean"/>
    </declare-styleable>

    <declare-styleable name="WaterDropRefractionView">
        <attr name="dropColor" format="color"/>
        <attr name="highlightColor" format="color"/>
        <attr name="shadowColor" format="color"/>
        <attr name="refractionIntensity" format="float"/>
        <attr name="waveAmplitude" format="dimension"/>
        <attr name="waveSpeed" format="float"/>
    </declare-styleable>
</resources>