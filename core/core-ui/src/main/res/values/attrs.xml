    <declare-styleable name="StatefulGlowView">
        <!-- 圆角 -->
        <attr name="sgv_cornerRadius" format="dimension" />
        <attr name="sgv_cornerRadiusTL" format="dimension" />
        <attr name="sgv_cornerRadiusTR" format="dimension" />
        <attr name="sgv_cornerRadiusBL" format="dimension" />
        <attr name="sgv_cornerRadiusBR" format="dimension" />
        <!-- 背景颜色 -->
        <attr name="sgv_overlayEnabled" format="boolean" />
        <attr name="sgv_overlayColorNormal" format="color" />
        <attr name="sgv_overlayColorPressed" format="color" />
        <attr name="sgv_overlayColorFocused" format="color" />
        <attr name="sgv_overlayColorSelected" format="color" />
        <attr name="sgv_overlayColorDisabled" format="color" />

        <attr name="sgv_strokeEnabled" format="boolean" />
        <!-- 描边宽度 -->
        <attr name="sgv_strokeWidthNormal" format="dimension" />
        <attr name="sgv_strokeWidthPressed" format="dimension" />
        <attr name="sgv_strokeWidthFocused" format="dimension" />
        <attr name="sgv_strokeWidthSelected" format="dimension" />
        <attr name="sgv_strokeWidthDisabled" format="dimension" />
        <!-- 描边颜色 -->
        <attr name="sgv_strokeColorNormal" format="color" />
        <attr name="sgv_strokeColorPressed" format="color" />
        <attr name="sgv_strokeColorFocused" format="color" />
        <attr name="sgv_strokeColorSelected" format="color" />
        <attr name="sgv_strokeColorDisabled" format="color" />

        <attr name="sgv_glowEnabled" format="boolean" />
        <!-- 内发光半径 -->
        <attr name="sgv_glowRadiusNormal" format="dimension" />
        <attr name="sgv_glowRadiusPressed" format="dimension" />
        <attr name="sgv_glowRadiusFocused" format="dimension" />
        <attr name="sgv_glowRadiusSelected" format="dimension" />
        <attr name="sgv_glowRadiusDisabled" format="dimension" />
        <!-- 内发光颜色 -->
        <attr name="sgv_glowColorNormal" format="color" />
        <attr name="sgv_glowColorPressed" format="color" />
        <attr name="sgv_glowColorFocused" format="color" />
        <attr name="sgv_glowColorSelected" format="color" />
        <attr name="sgv_glowColorDisabled" format="color" />
        <!-- 顶部高光 -->
        <attr name="sgv_topHighlightEnabled" format="boolean" />
        <attr name="sgv_topHighlightColor" format="color" />
    </declare-styleable>

    <!-- AnimatedStatefulGlowView: 带流光效果的状态化发光视图 -->
    <declare-styleable name="AnimatedStatefulGlowView">
        <!-- 流光开关 -->
        <attr name="asgv_flowEnabled" format="boolean" />
        <!-- 流光颜色（亮白色） -->
        <attr name="asgv_flowColor" format="color" />
        <!-- 流光一圈时长(ms) -->
        <attr name="asgv_flowDuration" format="integer" />
        <!-- 流光段占路径总长的比例 [0.05~0.6] -->
        <attr name="asgv_flowSegmentRatio" format="float" />
        <!-- 刷新效果开关 -->
        <attr name="asgv_refreshEffectEnabled" format="boolean" />
        <!-- 刷新扫描颜色 -->
        <attr name="asgv_refreshColor" format="color" />
    </declare-styleable>

    <!-- FrostedAnimatedGlowView: 毛玻璃发光视图 (BackgroundBlurDrawable 反射方案) -->
    <declare-styleable name="FrostedAnimatedGlowView">
        <!-- 模糊开关：启用即激活 BackgroundBlurDrawable + Window blurBehindRadius -->
        <attr name="fagv_useBackgroundBlurMode" format="boolean"/>
        <!-- 模糊半径 [0, 25] (Window blurBehindRadius) -->
        <attr name="fagv_backgroundBlurRadius" format="integer"/>
        <!-- 圆角半径 (BackgroundBlurDrawable.setCornerRadius) -->
        <attr name="fagv_backgroundBlurCornerRadius" format="float"/>
    </declare-styleable>

    <declare-styleable name="AnimatedScalableConstraintLayout">
        <!-- 统一圆角半径 -->
        <attr name="cornerRadius" format="dimension" />
        <!-- 各角独立圆角 -->
        <attr name="cornerRadiusTL" format="dimension" />
        <attr name="cornerRadiusTR" format="dimension" />
        <attr name="cornerRadiusBL" format="dimension" />
        <attr name="cornerRadiusBR" format="dimension" />
        <!-- 描边宽度 -->
        <attr name="strokeWidth" format="dimension" />
        <!-- 描边多状态颜色 -->
        <attr name="strokeColorNormal" format="color" />
        <attr name="strokeColorFocused" format="color" />
        <attr name="strokeColorPressed" format="color" />
        <attr name="strokeColorDisabled" format="color" />
        <!-- 填充多状态颜色 -->
        <attr name="fillColorNormal" format="color" />
        <attr name="fillColorFocused" format="color" />
        <attr name="fillColorPressed" format="color" />
        <attr name="fillColorDisabled" format="color" />
        <!-- 内发光开关 -->
        <attr name="glowEnabled" format="boolean" />
        <!-- 描边开关 -->
        <attr name="strokeEnabled" format="boolean" />
        <!-- 内阴影开关 -->
        <attr name="innerShadowEnabled" format="boolean" />
        <!-- 内发光半径（向中心延展的距离） -->
        <attr name="ascl_glowRadius" format="dimension" />
        <!-- 内发光多状态颜色 -->
        <attr name="glowColorNormal" format="color" />
        <attr name="glowColorFocused" format="color" />
        <attr name="glowColorPressed" format="color" />
        <attr name="glowColorDisabled" format="color" />
        <!-- 外阴影开关 -->
        <attr name="shadowEnabled" format="boolean" />
        <!-- 外阴影使用 elevation 方式（不需要 LAYER_TYPE_SOFTWARE） -->
        <attr name="shadowUseElevation" format="boolean" />
        <!-- 外阴影半径 -->
        <attr name="shadowRadius" format="dimension" />
        <!-- 外阴影偏移 -->
        <attr name="shadowDx" format="dimension" />
        <attr name="shadowDy" format="dimension" />
        <!-- 外阴影多状态颜色 -->
        <attr name="shadowColorNormal" format="color" />
        <attr name="shadowColorFocused" format="color" />
        <attr name="shadowColorPressed" format="color" />
        <attr name="shadowColorDisabled" format="color" />
        <!-- 内阴影多状态颜色 -->
        <attr name="innerShadowColorNormal" format="color" />
        <attr name="innerShadowColorFocused" format="color" />
        <attr name="innerShadowColorPressed" format="color" />
        <attr name="innerShadowColorDisabled" format="color" />
        <!-- 缩放比例 -->
        <attr name="scaleNormal" format="float" />
        <attr name="scaleFocused" format="float" />
        <attr name="scalePressed" format="float" />
        <attr name="scaleDisabled" format="float" />
    </declare-styleable>

    <!-- MeetingStatusView: 会议状态指示器 -->
    <declare-styleable name="MeetingStatusView">
        <!-- 背景颜色 -->
        <attr name="msv_backgroundColor" format="color" />
        <!-- 边框颜色 -->
        <attr name="msv_strokeColor" format="color" />
        <!-- 边框宽度 -->
        <attr name="msv_strokeWidth" format="dimension" />
        <!-- 是否启用描边 -->
        <attr name="msv_strokeEnabled" format="boolean" />
        <!-- 圆角半径（统一设置） -->
        <attr name="msv_cornerRadius" format="dimension" />
        <!-- 左上角圆角 -->
        <attr name="msv_cornerRadiusTL" format="dimension" />
        <!-- 右上角圆角 -->
        <attr name="msv_cornerRadiusTR" format="dimension" />
        <!-- 右下角圆角 -->
        <attr name="msv_cornerRadiusBR" format="dimension" />
        <!-- 左下角圆角 -->
        <attr name="msv_cornerRadiusBL" format="dimension" />
        <!-- 顶部高光是否启用 -->
        <attr name="msv_topHighlightEnabled" format="boolean" />
        <!-- 顶部高光颜色 -->
        <attr name="msv_topHighlightColor" format="color" />
        <!-- 顶部高光高度 -->
        <attr name="msv_topHighlightHeight" format="dimension" />
        <!-- 文本内容 -->
        <attr name="msv_text" format="string" />
        <!-- 文本颜色 -->
        <attr name="msv_textColor" format="color" />
        <!-- 文本大小 -->
        <attr name="msv_textSize" format="dimension" />
        <!-- 底部发光条颜色 -->
        <attr name="msv_glowBarColor" format="color" />
        <!-- 底部发光条高度 -->
        <attr name="msv_glowBarHeight" format="dimension" />
        <!-- 底部发光条圆角 -->
        <attr name="msv_glowBarCornerRadius" format="dimension" />
        <!-- 是否显示底部发光条 -->
        <attr name="msv_glowBarEnabled" format="boolean" />
        <!-- 是否启用触摸反馈 -->
        <attr name="msv_touchFeedbackEnabled" format="boolean" />
    </declare-styleable>

    <!-- WallpaperBlurView V2: 壁纸毛玻璃视图 (Compositor Blur, Android 12+, 系统权限) -->
    <declare-styleable name="WallpaperBlurView">
        <!-- ========== 模糊 ========== -->
        <!-- 模糊开关 -->
        <attr name="wbv_blurEnabled" format="boolean" />
        <!-- 模糊半径 [0,25] px (Compositor Blur 由 SurfaceFlinger GPU 执行) -->
        <attr name="wbv_blurRadius" format="float" />

        <!-- ========== 壁纸模式 ========== -->
        <!-- 0=AUTO, 1=STATIC, 2=DYNAMIC (V2 Compositor Blur 自动适配) -->
        <attr name="wbv_wallpaperMode" format="enum">
            <enum name="auto" value="0" />
            <enum name="static_wp" value="1" />
            <enum name="dynamic_wp" value="2" />
        </attr>

        <!-- ========== 圆角 ========== -->
        <attr name="wbv_cornerRadius" format="dimension" />
        <attr name="wbv_cornerRadiusTL" format="dimension" />
        <attr name="wbv_cornerRadiusTR" format="dimension" />
        <attr name="wbv_cornerRadiusBR" format="dimension" />
        <attr name="wbv_cornerRadiusBL" format="dimension" />

        <!-- ========== 蒙层 ========== -->
        <attr name="wbv_overlayEnabled" format="boolean" />
        <attr name="wbv_overlayColorNormal" format="color" />
        <attr name="wbv_overlayColorPressed" format="color" />
        <attr name="wbv_overlayColorFocused" format="color" />
        <attr name="wbv_overlayColorSelected" format="color" />
        <attr name="wbv_overlayColorDisabled" format="color" />

        <!-- ========== 描边 ========== -->
        <attr name="wbv_strokeEnabled" format="boolean" />
        <!-- 描边宽度（5状态） -->
        <attr name="wbv_strokeWidthNormal" format="dimension" />
        <attr name="wbv_strokeWidthPressed" format="dimension" />
        <attr name="wbv_strokeWidthFocused" format="dimension" />
        <attr name="wbv_strokeWidthSelected" format="dimension" />
        <attr name="wbv_strokeWidthDisabled" format="dimension" />
        <!-- 描边颜色（5状态） -->
        <attr name="wbv_strokeColorNormal" format="color" />
        <attr name="wbv_strokeColorPressed" format="color" />
        <attr name="wbv_strokeColorFocused" format="color" />
        <attr name="wbv_strokeColorSelected" format="color" />
        <attr name="wbv_strokeColorDisabled" format="color" />

        <!-- ========== 内发光 ========== -->
        <attr name="wbv_glowEnabled" format="boolean" />
        <!-- 内发光半径（5状态） -->
        <attr name="wbv_glowRadiusNormal" format="dimension" />
        <attr name="wbv_glowRadiusPressed" format="dimension" />
        <attr name="wbv_glowRadiusFocused" format="dimension" />
        <attr name="wbv_glowRadiusSelected" format="dimension" />
        <attr name="wbv_glowRadiusDisabled" format="dimension" />
        <!-- 内发光颜色（5状态） -->
        <attr name="wbv_glowColorNormal" format="color" />
        <attr name="wbv_glowColorPressed" format="color" />
        <attr name="wbv_glowColorFocused" format="color" />
        <attr name="wbv_glowColorSelected" format="color" />
        <attr name="wbv_glowColorDisabled" format="color" />

        <!-- ========== 顶部高光 ========== -->
        <attr name="wbv_topHighlightEnabled" format="boolean" />
        <attr name="wbv_topHighlightColor" format="color" />
    </declare-styleable>

    <!-- BlurView: 0延时内容模糊视图 (BackgroundBlurDrawable 反射方案, API 31+) -->
    <declare-styleable name="BlurView">
        <!-- 模糊开关：true 即启用系统 BackgroundBlurDrawable + Window blurBehindRadius -->
        <attr name="bv_blurEnabled" format="boolean"/>
        <!-- 模糊半径 [0, 25]，控制 SurfaceFlinger 模糊强度 -->
        <attr name="bv_blurRadius" format="integer"/>
        <!-- 外部预渲染 Drawable，设置后直接作为背景，跳过所有模糊处理 -->
        <attr name="bv_blurredDrawable" format="reference"/>
    </declare-styleable>
