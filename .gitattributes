# Auto-detect text files and normalize line endings to LF on commit
* text=auto

# Source code
*.kt       text eol=lf
*.java     text eol=lf
*.xml      text eol=lf
*.kts      text eol=lf
*.gradle   text eol=lf
*.properties text eol=lf

# Scripts
*.sh       text eol=lf
*.bat      text eol=crlf

# Config
*.toml     text eol=lf
*.yaml     text eol=lf
*.yml      text eol=lf
*.json     text eol=lf

# Documentation
*.md       text eol=lf

# Generated / compiled
*.pro      text eol=lf

# Binaries (prevent diff)
*.png      binary
*.jpg      binary
*.jpeg     binary
*.webp     binary
*.gif      binary
*.svg      text eol=lf
*.jar      binary
*.aar      binary
*.apk      binary
*.aab      binary
*.dex      binary
*.so       binary
*.ttf      binary
*.otf      binary
*.bin      binary
*.keystore binary
*.jks      binary
